# =============================================================================
# JOB HUNTING NOTEBOOK NAMESPACE - TypeDB 3.x Schema Extension
# =============================================================================
# Domain-specific subtypes for job hunting and career management.
# TypeDB as Claude's "world model" for reasoning about jobs, skills, and fit.
# Namespace prefix: jobhunt-*
# =============================================================================

define

# -----------------------------------------------------------------------------
# ATTRIBUTE TYPES - Job Hunting Specific
# -----------------------------------------------------------------------------

# URL attributes
attribute job-url, value string;
attribute company-url, value string;
attribute resource-url, value string;
attribute linkedin-url, value string;

# Position attributes
attribute short-name, value string;
attribute salary-range, value string;
attribute location, value string;
attribute remote-policy, value string;
attribute team-size, value string;

# Application tracking
attribute application-status, value string;
attribute applied-date, value datetime;
attribute interview-date, value datetime;
attribute deadline, value datetime;
attribute response-date, value datetime;

# Opportunity model attributes
attribute opportunity-status, value string;   # exploring/active/paused/closed
attribute engagement-type, value string;      # hourly | project | retainer | advisory
attribute rate-info, value string;            # free text: "$X/hr", "TBD", "equity only"
attribute venture-stage, value string;        # exploring | proposal-sent | negotiating | active | paused | closed
attribute equity-type, value string;          # none | advisor | cofounder | investor

# Skill/requirement attributes
attribute skill-name, value string;
attribute skill-level, value string;
attribute your-level, value string;

# Learning resource attributes
attribute resource-type, value string;
attribute estimated-hours, value integer;
attribute completion-status, value string;

# Contact attributes
attribute contact-role, value string;
attribute contact-email, value string;

# Fit analysis
attribute fit-score, value double;
attribute fit-summary, value string;

# Interaction tracking
attribute interaction-type, value string;
attribute interaction-date, value datetime;

# Priority
attribute priority-level, value string;

# Your skill profile attributes
attribute last-updated, value datetime;

# Forager attributes (automated job discovery)
attribute board-token, value string;
attribute board-platform, value string;
attribute external-job-id, value string;
attribute discovered-at, value datetime;
attribute relevance-score, value double;
attribute candidate-status, value string;
attribute search-query, value string;
attribute search-location, value string;
attribute triage-reason, value string;


# -----------------------------------------------------------------------------
# RELATION TYPES - defined before entities so role names resolve in plays clauses
# -----------------------------------------------------------------------------

# OPPORTUNITY-AT-ORGANIZATION - Links any opportunity to an organization
relation opportunity-at-organization,
    relates opportunity,
    relates organization;

# POSITION-AT-COMPANY - Links position to employer
relation position-at-company,
    relates position,
    relates employer;

# REQUIREMENT-FOR - Links requirements to positions
relation requirement-for,
    relates requirement,
    relates position;

# ADDRESSES-REQUIREMENT - Learning resources that address skill gaps
relation addresses-requirement,
    owns confidence,
    relates resource,
    relates requirement;

# SOURCE-PROVIDES - Links forager candidates to their search source
relation source-provides,
    relates source,
    relates candidate;

# WORKS-AT - Contacts working at companies
relation works-at,
    owns valid-from,
    owns valid-until,
    relates employee,
    relates employer;


# -----------------------------------------------------------------------------
# ENTITY TYPES - Job Hunting Collections
# -----------------------------------------------------------------------------

# JOBHUNT-SEARCH - A job search campaign (set of positions being tracked together)
entity jobhunt-search sub collection;


# -----------------------------------------------------------------------------
# ENTITY TYPES - Your Profile
# -----------------------------------------------------------------------------

# YOUR-SKILL - Your personal skill/capability for gap analysis
entity your-skill sub domain-thing,
    owns skill-name,
    owns skill-level,
    owns last-updated;


# -----------------------------------------------------------------------------
# ENTITY TYPES - Job Hunting Things
# -----------------------------------------------------------------------------

# JOBHUNT-SEARCH-SOURCE - A company job board to search (forager)
entity jobhunt-search-source sub domain-thing,
    owns board-token,
    owns board-platform,
    owns company-url,
    owns search-query,
    owns search-location,
    plays source-provides:source;

# JOBHUNT-CANDIDATE - A discovered job posting (forager, lightweight)
entity jobhunt-candidate sub domain-thing,
    owns job-url,
    owns external-job-id,
    owns location,
    owns discovered-at,
    owns relevance-score,
    owns candidate-status,
    owns triage-reason,
    plays source-provides:candidate;

# JOBHUNT-COMPANY - An organization/employer
entity jobhunt-company sub domain-thing,
    owns company-url,
    owns linkedin-url,
    owns location,
    plays position-at-company:employer,
    plays works-at:employer,
    plays opportunity-at-organization:organization;

# JOBHUNT-OPPORTUNITY - Base supertype for all trackable career opportunities
entity jobhunt-opportunity sub domain-thing,
    owns opportunity-status,
    owns priority-level,
    owns deadline,
    plays opportunity-at-organization:opportunity;

# JOBHUNT-POSITION - A specific role/job posting (formal employment application)
entity jobhunt-position sub jobhunt-opportunity,
    owns job-url,
    owns short-name,
    owns salary-range,
    owns location,
    owns remote-policy,
    owns team-size,
    plays position-at-company:position,
    plays requirement-for:position;

# JOBHUNT-ENGAGEMENT - Paid consulting/service work for a client
entity jobhunt-engagement sub jobhunt-opportunity,
    owns short-name,
    owns engagement-type,
    owns rate-info;

# JOBHUNT-VENTURE - Startup/advisory/equity opportunity
entity jobhunt-venture sub jobhunt-opportunity,
    owns short-name,
    owns venture-stage,
    owns equity-type;

# JOBHUNT-LEAD - Early-stage networking contact with undefined role
entity jobhunt-lead sub jobhunt-opportunity,
    owns short-name;

# JOBHUNT-LEARNING-RESOURCE - Course, tutorial, book, etc.
entity jobhunt-learning-resource sub domain-thing,
    owns resource-type,
    owns resource-url,
    owns estimated-hours,
    owns completion-status,
    plays addresses-requirement:resource;

# JOBHUNT-CONTACT - A person at a company
entity jobhunt-contact sub agent,
    owns contact-role,
    owns contact-email,
    owns linkedin-url,
    plays works-at:employee;


# -----------------------------------------------------------------------------
# ENTITY TYPES - Job Hunting Artifacts
# -----------------------------------------------------------------------------

entity jobhunt-job-description sub artifact;
entity jobhunt-resume sub artifact;
entity jobhunt-cover-letter sub artifact;
entity jobhunt-company-page sub artifact;
entity jobhunt-proposal sub artifact;


# -----------------------------------------------------------------------------
# ENTITY TYPES - Job Hunting Fragments (extracted from job descriptions)
# -----------------------------------------------------------------------------

# JOBHUNT-REQUIREMENT - A single requirement extracted from JD
entity jobhunt-requirement sub fragment,
    owns skill-name,
    owns skill-level,
    owns your-level,
    plays requirement-for:requirement,
    plays addresses-requirement:requirement;

entity jobhunt-responsibility sub fragment;
entity jobhunt-qualification sub fragment;


# -----------------------------------------------------------------------------
# ENTITY TYPES - Job Hunting Notes
# -----------------------------------------------------------------------------

entity jobhunt-application-note sub note,
    owns application-status,
    owns applied-date,
    owns response-date;

entity jobhunt-research-note sub note;

entity jobhunt-interview-note sub note,
    owns interview-date;

entity jobhunt-strategy-note sub note;
entity jobhunt-skill-gap-note sub note;

entity jobhunt-fit-analysis-note sub note,
    owns fit-score,
    owns fit-summary;

entity jobhunt-interaction-note sub note,
    owns interaction-type,
    owns interaction-date;


# -----------------------------------------------------------------------------
# CROSS-NAMESPACE EXTENSIONS
# -----------------------------------------------------------------------------

# Allow paper collections to address skill requirements (bridges scilit <-> jobhunt)
collection plays addresses-requirement:resource;


# =============================================================================
# END JOB HUNTING NAMESPACE
# =============================================================================
